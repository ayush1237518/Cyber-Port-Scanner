<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.portscanner.ui.ScannerController"
            styleClass="root-pane">

    <!-- ===================== HEADER ===================== -->
    <top>
        <VBox styleClass="header-bar">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="header-inner">
                <Label text="🛡" styleClass="header-icon"/>
                <VBox spacing="2">
                    <Label text="NETWORK PORT SCANNER" styleClass="header-title"/>
                    <Label text="Cybersecurity Reconnaissance Toolkit" styleClass="header-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusPill" text="IDLE" styleClass="status-pill,status-idle"/>
            </HBox>
        </VBox>
    </top>

    <!-- ===================== LEFT: CONFIGURATION PANEL ===================== -->
    <left>
        <ScrollPane fitToWidth="true" styleClass="config-scroll">
            <VBox spacing="16" styleClass="config-panel">
                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>

                <Label text="SCAN CONFIGURATION" styleClass="section-title"/>

                <VBox spacing="6">
                    <Label text="Target IP / Hostname" styleClass="field-label"/>
                    <TextField fx:id="targetField" promptText="e.g. 192.168.1.1 or example.com"
                               styleClass="input-field">
                        <tooltip>
                            <Tooltip text="Enter an IPv4 address or a resolvable hostname."/>
                        </tooltip>
                    </TextField>
                </VBox>

                <HBox spacing="10">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Start Port" styleClass="field-label"/>
                        <TextField fx:id="startPortField" text="1" styleClass="input-field">
                            <tooltip>
                                <Tooltip text="First port in the scan range (1-65535)."/>
                            </tooltip>
                        </TextField>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="End Port" styleClass="field-label"/>
                        <TextField fx:id="endPortField" text="1024" styleClass="input-field">
                            <tooltip>
                                <Tooltip text="Last port in the scan range (1-65535)."/>
                            </tooltip>
                        </TextField>
                    </VBox>
                </HBox>

                <HBox spacing="10">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Timeout (ms)" styleClass="field-label"/>
                        <TextField fx:id="timeoutField" text="500" styleClass="input-field">
                            <tooltip>
                                <Tooltip text="Socket connect timeout per port, in milliseconds."/>
                            </tooltip>
                        </TextField>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Threads" styleClass="field-label"/>
                        <TextField fx:id="threadCountField" text="100" styleClass="input-field">
                            <tooltip>
                                <Tooltip text="Number of concurrent worker threads (1-500)."/>
                            </tooltip>
                        </TextField>
                    </VBox>
                </HBox>

                <CheckBox fx:id="bannerGrabCheckBox" text="Enable Banner Grabbing" selected="true"
                          styleClass="check-box">
                    <tooltip>
                        <Tooltip text="Attempt to read service banners from open ports."/>
                    </tooltip>
                </CheckBox>

                <Separator/>

                <HBox spacing="10">
                    <Button fx:id="scanButton" text="▶  START SCAN" styleClass="btn-primary" onAction="#onScanClicked"
                            HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <tooltip>
                            <Tooltip text="Start scanning (Ctrl+Enter)"/>
                        </tooltip>
                    </Button>
                </HBox>
                <Button fx:id="stopButton" text="■  STOP SCAN" styleClass="btn-danger" onAction="#onStopClicked"
                        disable="true" maxWidth="Infinity">
                    <tooltip>
                        <Tooltip text="Cancel the running scan (Esc)"/>
                    </tooltip>
                </Button>

                <Separator/>

                <Label text="PROGRESS" styleClass="section-title"/>
                <ProgressBar fx:id="progressBar" progress="0" maxWidth="Infinity" styleClass="neon-progress"/>
                <Label fx:id="progressLabel" text="0% — 0 / 0 ports" styleClass="progress-label"/>
                <GridPane hgap="8" vgap="4" styleClass="progress-grid">
                    <Label text="Elapsed:" styleClass="stat-key" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="elapsedTimeLabel" text="00:00:00" styleClass="stat-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Remaining:" styleClass="stat-key" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="remainingTimeLabel" text="--:--:--" styleClass="stat-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                </GridPane>

                <Separator/>

                <Label text="SCAN SUMMARY" styleClass="section-title"/>
                <GridPane hgap="10" vgap="8" styleClass="summary-card">
                    <Label text="Total" styleClass="stat-key" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="totalPortsLabel" text="0" styleClass="stat-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Open" styleClass="stat-key-open" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="openPortsLabel" text="0" styleClass="stat-value-open" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Closed" styleClass="stat-key-closed" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="closedPortsLabel" text="0" styleClass="stat-value-closed" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Filtered" styleClass="stat-key-filtered" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <Label fx:id="filteredPortsLabel" text="0" styleClass="stat-value-filtered" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Errors" styleClass="stat-key-error" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                    <Label fx:id="errorPortsLabel" text="0" styleClass="stat-value-error" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                    <Label text="Duration" styleClass="stat-key" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                    <Label fx:id="durationLabel" text="00:00:00" styleClass="stat-value" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                </GridPane>
            </VBox>
        </ScrollPane>
    </left>

    <!-- ===================== CENTER: RESULTS + LOG ===================== -->
    <center>
        <SplitPane dividerPositions="0.68" orientation="VERTICAL" styleClass="center-split">
            <VBox spacing="10" styleClass="results-panel">
                <padding>
                    <Insets top="16" right="16" bottom="8" left="8"/>
                </padding>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="SCAN RESULTS" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="filterField" promptText="Filter by port, status or service..."
                               styleClass="input-field,search-field" prefWidth="260">
                        <tooltip>
                            <Tooltip text="Live filter across port, status, service and banner (Ctrl+F to focus)"/>
                        </tooltip>
                    </TextField>
                    <MenuButton text="⭳ Export" styleClass="btn-secondary">
                        <items>
                            <MenuItem text="Export as CSV" onAction="#onExportCsv"/>
                            <MenuItem text="Export as JSON" onAction="#onExportJson"/>
                            <MenuItem text="Export as TXT" onAction="#onExportTxt"/>
                        </items>
                    </MenuButton>
                    <Button text="✕ Clear" styleClass="btn-secondary" onAction="#onClearClicked">
                        <tooltip>
                            <Tooltip text="Clear all results (Ctrl+L)"/>
                        </tooltip>
                    </Button>
                </HBox>

                <TableView fx:id="resultsTable" styleClass="results-table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="portColumn" text="PORT" prefWidth="80"/>
                        <TableColumn fx:id="statusColumn" text="STATUS" prefWidth="110"/>
                        <TableColumn fx:id="serviceColumn" text="SERVICE" prefWidth="140"/>
                        <TableColumn fx:id="responseTimeColumn" text="RESPONSE TIME" prefWidth="130"/>
                        <TableColumn fx:id="bannerColumn" text="BANNER" prefWidth="360"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <VBox spacing="6" styleClass="log-panel">
                <padding>
                    <Insets top="8" right="16" bottom="12" left="8"/>
                </padding>
                <Label text="LIVE ACTIVITY LOG" styleClass="section-title"/>
                <TextArea fx:id="logArea" editable="false" wrapText="true" styleClass="log-area" VBox.vgrow="ALWAYS"/>
            </VBox>
        </SplitPane>
    </center>

    <!-- ===================== FOOTER ===================== -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="footer-bar">
            <padding>
                <Insets top="6" right="16" bottom="6" left="16"/>
            </padding>
            <Label text="Network Port Scanner v1.0" styleClass="footer-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Shortcuts:  Ctrl+Enter Scan   •   Esc Stop   •   Ctrl+L Clear   •   Ctrl+F Filter"
                   styleClass="footer-text"/>
        </HBox>
    </bottom>

</BorderPane>
